//@version=6
indicator("SMC Toolkit - BOS", overlay=true)

length = input.int(5, "Swing Length", minval=1)

swingHigh = ta.pivothigh(high, length, length)
swingLow = ta.pivotlow(low, length, length)

var float lastHigh = na
var float lastLow = na

if not na(swingHigh)
    lastHigh := swingHigh

if not na(swingLow)
    lastLow := swingLow

bullishBOS = not na(lastHigh) and close > lastHigh
bearishBOS = not na(lastLow) and close < lastLow

plotshape(bullishBOS, title="Bullish BOS", location=location.belowbar, style=shape.triangleup, text="BOS")
plotshape(bearishBOS, title="Bearish BOS", location=location.abovebar, style=shape.triangledown, text="BOS")
